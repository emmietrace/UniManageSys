@model UniManageSys.ViewModels.StudentDashboardViewModel

@{
    ViewData["Title"] = "Course Registration";
    
    // Calculate progress bar percentage
    int percentage = Model.CurrentSemester != null
        ? (int)Math.Round((double)Model.TotalRegisteredCredits / Model.MaxCredits * 100)
        : 0;
        
    string barColor = percentage > 90 ? "bg-danger" : percentage > 75 ? "bg-warning" : "bg-success";
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 8px;">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 8px; border-left: 5px solid #10B981;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.CurrentSemester == null)
{
    <div class="text-center mt-5 p-5 card border-0 shadow-sm" style="border-radius: 16px;">
        <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
        <h4 class="mt-3 fw-bold" style="color: var(--brand-navy);">Portal Closed</h4>
        <p class="text-muted">There is currently no active academic semester. Please contact the Registrar.</p>
    </div>
}
else
{
    <div class="row g-4 mt-2 mb-5">
        
        <div class="col-lg-8">
            <h5 class="fw-bold mb-3" style="color: var(--brand-navy);">Available Courses</h5>
            
            <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
                <table class="uni-table w-100 mb-0">
                    <thead style="background-color: #F8FAFC;">
                        <tr>
                            <th class="ps-4">Code</th>
                            <th>Title</th>
                            <th>Units</th>
                            <th>Requirements</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.AvailableCourses.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No available courses to register.</td></tr>
                        }
                        @foreach (var course in Model.AvailableCourses)
                        {
                            <tr>
                                <td class="fw-bold ps-4" style="color: var(--brand-navy);">@course.Code</td>
                                <td style="font-weight: 500;">@course.Title</td>
                                <td><span class="badge bg-light text-dark border">@course.CreditUnits Units</span></td>
                                <td>
                                    @if (course.Prerequisites.Any())
                                    {
                                        <span class="text-danger" style="font-size: 0.8rem;"><i class="bi bi-lock-fill"></i> Pre-reqs required</span>
                                    }
                                    else
                                    {
                                        <span class="text-success" style="font-size: 0.8rem;"><i class="bi bi-unlock-fill"></i> None</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <form asp-action="AddCourse" method="post">
                                        <input type="hidden" name="courseId" value="@course.Id" />
                                        <button type="submit" class="btn btn-sm shadow-sm" style="background-color: var(--brand-navy); color: white; border-radius: 6px;">
                                            <i class="bi bi-plus-lg"></i> Add
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 sticky-top" style="top: 2rem; border-radius: 16px; background-color: var(--brand-navy); color: white;">
                
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div>
                        <h5 class="fw-bold text-white mb-0">My Registrations</h5>
                        <p style="color: #94A3B8; font-size: 0.85rem; margin-top: 2px;">@Model.CurrentSemester.AcademicYear?.Name - @Model.CurrentSemester.Name</p>
                    </div>
                    
                    @if (Model.CurrentRegistrations.Any(r => r.Status != UniManageSys.Enums.RegistrationStatus.Approved))
                    {
                        <form asp-controller="Registration" asp-action="ResetCart" method="post" onsubmit="return confirm('Are you sure you want to drop all unapproved courses? This cannot be undone.');">
                            <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 6px; padding: 2px 8px; font-size: 0.8rem;" title="Reset Cart">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    }
                </div>

                <div class="mt-3 mb-2 d-flex justify-content-between align-items-end">
                    <span style="font-size: 0.85rem; color: #CBD5E1; text-transform: uppercase; letter-spacing: 0.05em;">Total Credits</span>
                    <span class="fw-bold fs-4 text-white">@Model.TotalRegisteredCredits<span style="font-size: 1rem; color: #94A3B8;"> / @Model.MaxCredits</span></span>
                </div>
                
                <div class="progress mb-4" style="height: 8px; background-color: #1E293B; border-radius: 4px;">
                    <div class="progress-bar @barColor" role="progressbar" style="width: @percentage%; border-radius: 4px;" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                </div>

                <div class="d-flex flex-column gap-2">
                    @if (!Model.CurrentRegistrations.Any())
                    {
                        <div class="text-center p-3" style="background-color: #1E293B; border-radius: 8px; color: #94A3B8; font-size: 0.9rem;">
                            No courses added yet.
                        </div>
                    }
                    @foreach (var reg in Model.CurrentRegistrations)
                    {
                        <div class="p-3 d-flex justify-content-between align-items-center" style="background-color: #1E293B; border-radius: 8px;">
                            <div>
                                <div class="fw-bold text-white" style="font-size: 0.95rem;">@reg.Course?.Code</div>
                                <div style="color: var(--brand-gold); font-size: 0.75rem; font-weight: 600;">@reg.Status.ToString().ToUpper()</div>
                            </div>
                            
                            <div class="d-flex align-items-center gap-3">
                                <div class="fw-bold text-white">@reg.Course?.CreditUnits <span style="font-size: 0.7rem; color: #94A3B8; font-weight: normal;">CR</span></div>
                                
                                @if (reg.Status != UniManageSys.Enums.RegistrationStatus.Approved)
                                {
                                    <form asp-controller="Registration" asp-action="DropCourse" asp-route-id="@reg.Id" method="post" class="m-0">
                                        <button type="submit" class="btn btn-sm btn-danger p-1 shadow-sm d-flex align-items-center justify-content-center" style="border-radius: 6px; width: 24px; height: 24px;" title="Drop Course">
                                            <i class="bi bi-x" style="font-size: 1.2rem; line-height: 0;"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <i class="bi bi-lock-fill text-success" title="Approved & Locked"></i>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (Model.CurrentRegistrations.Any(r => r.Status == UniManageSys.Enums.RegistrationStatus.Draft))
                {
                    <form asp-action="Submit" method="post" class="mt-4">
                        <button type="submit" class="btn w-100 py-2 shadow-sm" style="background-color: var(--brand-gold); color: var(--brand-navy); font-weight: 700; border-radius: 8px;">
                            <i class="bi bi-send-fill me-1"></i> Submit for Approval
                        </button>
                    </form>
                }
                else if (Model.CurrentRegistrations.Any())
                {
                    <div class="alert mt-4 mb-0 text-center" style="background-color: rgba(16, 185, 129, 0.1); border: 1px solid #10B981; color: #10B981; border-radius: 8px;">
                        <i class="bi bi-clock-history me-1"></i> Registration Submitted
                    </div>
                }
            </div>
        </div>
    </div>
}