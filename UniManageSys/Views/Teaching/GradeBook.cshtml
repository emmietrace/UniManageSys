@model UniManageSys.ViewModels.GradebookViewModel

@{
    ViewData["Title"] = "Gradebook - " + Model.Assignment.Course?.Code;
}

<div class="card border-0 shadow-sm p-4" style="border-radius: 16px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0" style="color: var(--brand-navy);">Gradebook: @Model.Assignment.Course?.Code</h4>
        <a asp-action="MyClasses" class="btn btn-sm btn-outline-secondary">Back to Classes</a>
    </div>

    @if (!Model.RegisteredStudents.Any())
    {
        <div class="alert alert-info text-center p-5">
            <i class="bi bi-people mb-3 d-block" style="font-size: 2rem;"></i>
            No students are currently approved for this course.
        </div>
    }
    else
    {
        <table class="uni-table w-100">
            <thead>
                <tr>
                    <th>Matric No.</th>
                    <th>Name</th>
                    <th style="width: 100px;">CA (30)</th>
                    <th style="width: 100px;">Exam (70)</th>
                    <th>Total</th>
                    <th>Grade</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in Model.RegisteredStudents)
                {
                    <tr>
                        <td>@reg.Student?.MatriculationNumber</td>
                        <td>@reg.Student?.User?.FullName</td>
                        <form asp-action="SaveScore" method="post">
                            <input type="hidden" name="registrationId" value="@reg.Id" />
                            <input type="hidden" name="assignmentId" value="@Model.Assignment.Id" />
                            <td><input type="number" name="caScore" class="form-control form-control-sm" value="@reg.Result?.ContinuousAssessment" max="30" /></td>
                            <td><input type="number" name="examScore" class="form-control form-control-sm" value="@reg.Result?.ExamScore" max="70" /></td>
                            <td class="fw-bold">@(reg.Result?.TotalScore ?? 0)</td>
                            <td><span class="badge @(reg.Result?.Grade == "F" ? "bg-danger" : "bg-success")">@(reg.Result?.Grade ?? "-")</span></td>
                            <td><button type="submit" class="btn btn-sm btn-dark">Save</button></td>
                        </form>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>