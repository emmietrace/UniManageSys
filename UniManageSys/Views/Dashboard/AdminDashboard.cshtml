@model UniManageSys.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Portal";
}

<div class="d-flex justify-content-between align-items-end mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--brand-navy); letter-spacing: -0.5px;">University Overview</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem;">Active Term: @(Model.ActiveSemester?.Name ?? "None")</p>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-5">
    
    <div class="col">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1" style="letter-spacing: 0.05em;">Total Students</p>
                        <h2 class="fw-bold mb-0" style="color: var(--brand-navy);">@Model.TotalStudents</h2>
                    </div>
                    <div class="p-2 rounded" style="background-color: rgba(15, 23, 42, 0.05); color: var(--brand-navy);">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                </div>
                <a asp-controller="Students" asp-action="Index" class="text-decoration-none small fw-bold" style="color: var(--brand-navy);">View Directory &rarr;</a>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1" style="letter-spacing: 0.05em;">Total Staff</p>
                        <h2 class="fw-bold mb-0" style="color: var(--brand-navy);">@Model.TotalLecturers</h2>
                    </div>
                    <div class="p-2 rounded" style="background-color: rgba(16, 185, 129, 0.1); color: #10B981;">
                        <i class="bi bi-person-badge-fill fs-4"></i>
                    </div>
                </div>
                <a asp-controller="Lecturers" asp-action="Index" class="text-decoration-none small fw-bold" style="color: #10B981;">Manage Faculty &rarr;</a>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1" style="letter-spacing: 0.05em;">Courses</p>
                        <h2 class="fw-bold mb-0" style="color: var(--brand-navy);">@Model.TotalCourses</h2>
                    </div>
                    <div class="p-2 rounded" style="background-color: rgba(139, 92, 246, 0.1); color: #8B5CF6;">
                        <i class="bi bi-book-half fs-4"></i>
                    </div>
                </div>
                <a asp-controller="Courses" asp-action="Index" class="text-decoration-none small fw-bold" style="color: #8B5CF6;">View Curriculum &rarr;</a>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1" style="letter-spacing: 0.05em;">Pending Approvals</p>
                        <h2 class="fw-bold mb-0 @(Model.PendingRegistrations > 0 ? "text-danger" : "text-muted")">@Model.PendingRegistrations</h2>
                    </div>
                    <div class="p-2 rounded" style="background-color: @(Model.PendingRegistrations > 0 ? "rgba(239, 68, 68, 0.1)" : "rgba(100, 116, 139, 0.1)"); color: @(Model.PendingRegistrations > 0 ? "#EF4444" : "#64748b");">
                        <i class="bi bi-exclamation-circle-fill fs-4"></i>
                    </div>
                </div>
                
                @if (Model.PendingRegistrations > 0)
                {
                    <a asp-controller="Students" asp-action="PendingApprovals" class="text-danger text-decoration-none small fw-bold mt-2 d-inline-block">Review Now &rarr;</a>
                }
                else
                {
                    <span class="text-muted small fw-bold">All caught up!</span>
                }
            </div>
        </div>
    </div>

</div>

<div class="row g-4 mb-5">
    
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0" style="color: var(--brand-navy);">
                    <i class="bi bi-person-lines-fill me-2 text-muted"></i> Directory Quick View
                </h5>
                <a asp-controller="Students" asp-action="Index" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px;">View Full Registry</a>
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: #F8FAFC;">
                        <tr>
                            <th class="text-muted small fw-bold border-0 rounded-start ps-3">QUICK LINKS</th>
                            <th class="text-muted small fw-bold border-0 text-end rounded-end pe-3">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-3 fw-bold" style="color: var(--brand-navy);">Browse Student Registry</td>
                            <td class="text-end pe-3"><a asp-controller="Students" asp-action="Index" class="btn btn-sm btn-light">Go &rarr;</a></td>
                        </tr>
                        <tr>
                            <td class="ps-3 fw-bold" style="color: var(--brand-navy);">Manage Academic Programmes</td>
                            <td class="text-end pe-3"><a asp-controller="Programmes" asp-action="Index" class="btn btn-sm btn-light">Go &rarr;</a></td>
                        </tr>
                        <tr>
                            <td class="ps-3 fw-bold" style="color: var(--brand-navy);">Assign HODs / Faculty</td>
                            <td class="text-end pe-3"><a asp-controller="Lecturers" asp-action="Index" class="btn btn-sm btn-light">Go &rarr;</a></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px; background-color: var(--brand-navy); color: white;">
            <h5 class="fw-bold mb-4 text-white">
                <i class="bi bi-lightning-charge-fill me-2" style="color: var(--brand-gold);"></i> Admin Actions
            </h5>

            <div class="d-flex flex-column gap-3">
                <a asp-controller="Students" asp-action="Enroll" class="btn text-start p-3 border-0 d-flex justify-content-between align-items-center shadow-sm" style="background-color: rgba(255,255,255,0.05); border-radius: 12px; color: white;">
                    <div>
                        <div class="fw-bold text-white">Admit Student</div>
                        <div class="small text-white-50">Generate matric number</div>
                    </div>
                    <i class="bi bi-person-plus-fill" style="color: var(--brand-gold);"></i>
                </a>

                <a asp-controller="Lecturers" asp-action="Onboard" class="btn text-start p-3 border-0 d-flex justify-content-between align-items-center shadow-sm" style="background-color: rgba(255,255,255,0.05); border-radius: 12px; color: white;">
                    <div>
                        <div class="fw-bold text-white">Onboard Staff</div>
                        <div class="small text-white-50">Add faculty members</div>
                    </div>
                    <i class="bi bi-briefcase-fill" style="color: var(--brand-gold);"></i>
                </a>

                <a asp-controller="Semesters" asp-action="Index" class="btn text-start p-3 border-0 d-flex justify-content-between align-items-center shadow-sm" style="background-color: rgba(255,255,255,0.05); border-radius: 12px; color: white;">
                    <div>
                        <div class="fw-bold text-white">Manage Semesters</div>
                        <div class="small text-white-50">Open/Close academic terms</div>
                    </div>
                    <i class="bi bi-calendar-range-fill" style="color: var(--brand-gold);"></i>
                </a>
            </div>
        </div>
    </div>

</div>