@model UniManageSys.ViewModels.LecturerDashboardViewModel

@{
    ViewData["Title"] = "Lecturer Portal";
}

<div class="d-flex justify-content-between align-items-end mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--brand-navy); letter-spacing: -0.5px;">Welcome back, @Model.LecturerProfile.User.FirstName!</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem;">@Model.CurrentSemester.AcademicYear.Name - @Model.CurrentSemester.Name</p>
    </div>
    <div class="text-end">
        <span class="badge bg-light text-dark border p-2 shadow-sm">Department: @Model.LecturerProfile.Department?.Code</span>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-5">
    
    <div class="col">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1" style="letter-spacing: 0.05em;">My Courses</p>
                        <h2 class="fw-bold mb-0" style="color: var(--brand-navy);">@Model.AssignedCourses.Count</h2>
                    </div>
                    <div class="p-2 rounded" style="background-color: rgba(15, 23, 42, 0.05); color: var(--brand-navy);">
                        <i class="bi bi-journal-bookmark-fill fs-4"></i>
                    </div>
                </div>
                <a asp-controller="Lecturers" asp-action="Workload" asp-route-id="@Model.LecturerProfile.Id" class="text-decoration-none small fw-bold" style="color: var(--brand-navy);">View Curriculum &rarr;</a>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1" style="letter-spacing: 0.05em;">Total Students</p>
                        <h2 class="fw-bold mb-0" style="color: var(--brand-navy);">@Model.TotalStudents</h2>
                    </div>
                    <div class="p-2 rounded" style="background-color: rgba(245, 158, 11, 0.1); color: var(--brand-gold);">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                </div>
                <span class="small fw-bold text-muted">Across all active courses</span>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1" style="letter-spacing: 0.05em;">Classes Today</p>
                        <h2 class="fw-bold mb-0" style="color: var(--brand-navy);">@Model.TodaysLectures.Count</h2>
                    </div>
                    <div class="p-2 rounded" style="background-color: rgba(16, 185, 129, 0.1); color: #10B981;">
                        <i class="bi bi-calendar-event-fill fs-4"></i>
                    </div>
                </div>
                <a href="#schedule" class="text-decoration-none small fw-bold" style="color: #10B981;">View Schedule &rarr;</a>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1" style="letter-spacing: 0.05em;">Pending Actions</p>
                        <h2 class="fw-bold mb-0" style="color: var(--brand-navy);">Action</h2>
                    </div>
                    <div class="p-2 rounded" style="background-color: rgba(239, 68, 68, 0.1); color: #EF4444;">
                        <i class="bi bi-exclamation-square-fill fs-4"></i>
                    </div>
                </div>
                <a asp-controller="Attendance" asp-action="Index" class="text-decoration-none small fw-bold" style="color: #EF4444;">Mark Attendance &rarr;</a>
            </div>
        </div>
    </div>

</div>
<div class="row g-4">
    
    <div class="col-lg-8" id="schedule">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
            <h5 class="fw-bold mb-4" style="color: var(--brand-navy);">
                <i class="bi bi-clock-history me-2 text-muted"></i> Today's Teaching Schedule
            </h5>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: #F8FAFC;">
                        <tr>
                            <th class="text-muted small fw-bold border-0 rounded-start ps-3">TIME</th>
                            <th class="text-muted small fw-bold border-0">COURSE</th>
                            <th class="text-muted small fw-bold border-0 rounded-end pe-3">VENUE</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.TodaysLectures.Any())
                        {
                            @foreach (var cls in Model.TodaysLectures)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold" style="color: var(--brand-gold);">
                                        @cls.StartTime.ToString(@"hh\:mm") - @cls.EndTime.ToString(@"hh\:mm")
                                    </td>
                                    <td>
                                        <div class="fw-bold" style="color: var(--brand-navy);">@cls.Course?.Code</div>
                                        <div class="small text-muted">@cls.Course?.Title</div>
                                    </td>
                                    <td class="pe-3">
                                        <span class="badge bg-light text-dark border"><i class="bi bi-geo-alt-fill text-danger me-1"></i> @cls.Venue?.Name</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-5 border-0">
                                    <div class="mb-3"><i class="bi bi-cup-hot fs-1 text-muted opacity-50"></i></div>
                                    <h6 class="fw-bold" style="color: var(--brand-navy);">No lectures scheduled today.</h6>
                                    <p class="small mb-0">A perfect day for research and grading!</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px; background-color: var(--brand-navy); color: white;">
            <h5 class="fw-bold mb-4 text-white">
                <i class="bi bi-lightning-charge-fill me-2" style="color: var(--brand-gold);"></i> Quick Actions
            </h5>

            <div class="d-flex flex-column gap-3">
                <a asp-controller="Attendance" asp-action="Index" class="btn text-start p-3 border-0 d-flex justify-content-between align-items-center shadow-sm hover-lift" style="background-color: rgba(255,255,255,0.05); border-radius: 12px; color: white;">
                    <div>
                        <div class="fw-bold text-white">Mark Attendance</div>
                        <div class="small text-white-50">Record student presence</div>
                    </div>
                    <i class="bi bi-chevron-right" style="color: var(--brand-gold);"></i>
                </a>

                <a asp-controller="Teaching" asp-action="Gradebook" asp-route-id="2" class="btn text-start p-3 border-0 d-flex justify-content-between align-items-center shadow-sm hover-lift" style="background-color: rgba(255,255,255,0.05); border-radius: 12px; color: white;">
                    <div>
                        <div class="fw-bold text-white">Upload Results</div>
                        <div class="small text-white-50">Enter CA and Exam scores</div>
                    </div>
                    <i class="bi bi-chevron-right" style="color: var(--brand-gold);"></i>
                </a>

                @* <a href="#" class="btn text-start p-3 border-0 d-flex justify-content-between align-items-center shadow-sm hover-lift" style="background-color: rgba(255,255,255,0.05); border-radius: 12px; color: white;">
                    <div>
                        <div class="fw-bold text-white">Course Materials</div>
                        <div class="small text-white-50">Manage uploaded files</div>
                    </div>
                    <i class="bi bi-chevron-right" style="color: var(--brand-gold);"></i>
                </a> *@
            </div>
        </div>
    </div>

</div>