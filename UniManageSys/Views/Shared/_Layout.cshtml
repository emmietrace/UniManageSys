<!DOCTYPE html>
@using Microsoft.AspNetCore.Identity
@using UniManageSys.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <div class="app-container">
        
        <aside class="sidebar shadow-lg">
            <div class="sidebar-header">
                <h3 class="sidebar-brand">UniSystem</h3>
                <span class="sidebar-subtitle">Enterprise Edition</span>
            </div>
            
            <ul class="nav flex-column mb-auto">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid me-2"></i> Dashboard
                    </a>
                </li>

                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Registrar") || User.IsInRole("HOD"))
                {
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                        <span>Administration</span>
                    </h6>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Students" ? "active" : "")" asp-controller="Students" asp-action="Index">
                            <i class="bi bi-people me-2"></i> Students
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Lecturers" ? "active" : "")" asp-controller="Lecturers" asp-action="Index">
                            <i class="bi bi-person-badge me-2"></i> Lecturers
                        </a>
                    </li>
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                        <span>Academic Setup</span>
                    </h6>
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Registrar")) {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Departments" ? "active" : "")"
                                   asp-controller="Departments" asp-action="Index">
                                <i class="bi bi-building me-2"></i> Departments
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Programmes" ? "active" : "")"
                               asp-controller="Programmes" asp-action="Index">
                            <i class="bi bi-mortarboard me-2"></i> Programmes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Courses" ? "active" : "")"
                               asp-controller="Courses" asp-action="Index">
                            <i class="bi bi-book-half me-2"></i> Courses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Timetable" ? "active" : "")"
                               asp-controller="Timetable" asp-action="Schedule">
                            <i class="bi bi-calendar-range me-2"></i> Master Timetable
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "PendingApprovals" ? "active" : "")"
                               asp-controller="Students"
                               asp-action="PendingApprovals">
                            <i class="bi bi-check2-square me-2"></i> Pending Approvals
                        </a>
                    </li>
                    @* <li class="nav-item mt-2">
                        <a class="nav-link text-muted" href="#" title="Coming in Phase 7">
                            <i class="bi bi-wallet2 me-2"></i> Financial Control
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-muted" href="#" title="Coming in Phase 8">
                            <i class="bi bi-gear me-2"></i> Settings
                        </a>
                    </li> *@
                }

                @if (User.IsInRole("Student"))
                {
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                        <span>Academics</span>
                    </h6>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Registration" ? "active" : "")" asp-controller="Registration" asp-action="Portal">
                            <i class="bi bi-journal-plus me-2"></i> Course Registration
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Timetable" ? "active" : "")"
                               asp-controller="Timetable"
                               asp-action="MyTimetable">
                            <i class="bi bi-calendar-event me-2"></i> My Timetable
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Results" ? "active" : "")"
                               asp-controller="Results"
                               asp-action="MyTranscript">
                            <i class="bi bi-award me-2"></i> My Results
                        </a>
                    </li>
                    <a class="nav-link" asp-controller="Profile" asp-action="Index">
                        <i class="bi bi-person-circle me-2"></i> Profile & Settings
                    </a>
                    <li class="nav-item mt-2">
                        <a class="nav-link text-muted" href="#" title="Coming in Phase 7">
                            <i class="bi bi-credit-card me-2"></i> Fee Payment
                        </a>
                    </li>

                }

                @if (User.IsInRole("Lecturer"))
                {
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                        <span>Teaching & Grading</span>
                    </h6>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Teaching" ? "active" : "")" asp-controller="Teaching" asp-action="MyClasses">
                            <i class="bi bi-journal-check me-2"></i> My Classes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Attendance" ? "active" : "")"
                               asp-controller="Attendance" asp-action="Index">
                            <i class="bi bi-clipboard-check me-2"></i> Attendance
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MyClasses" ? "active" : "")"
                               asp-controller="Teaching" asp-action="MyClasses">
                            <i class="bi bi-clipboard2-data me-2"></i> Gradebook
                        </a>
                    </li>
                    <a class="nav-link" asp-controller="Profile" asp-action="Index">
                        <i class="bi bi-person-circle me-2"></i> Profile & Settings
                    </a>
                }
            </ul>
            <div class="mt-auto p-3 border-top" style="border-color: rgba(255,255,255,0.05);">
                @if (SignInManager.IsSignedIn(User))
                {
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                        <button type="submit" class="nav-link w-100 bg-transparent border-0 text-start" style="color: #ef4444; transition: all 0.2s;">
                            <i class="bi bi-box-arrow-right"></i> <span class="ms-1">Sign Out</span>
                        </button>
                    </form>
                }
                else
                {
                    <a class="nav-link" asp-area="Identity" asp-page="/Account/Register" style="color: var(--brand-gold);">
                        <i class="bi bi-person-plus"></i> <span class="ms-1">Register Portal</span>
                    </a>
                }
            </div>
        </aside>

        <main class="main-content">
            <header class="top-header border-bottom" style="border-color: #E2E8F0;">
                <h1 class="page-title">@ViewData["Title"]</h1>
                
                <div class="d-flex align-items-center gap-4">
                    <span class="text-muted fw-medium d-none d-md-block" style="font-size: 0.9rem;"><i class="bi bi-calendar3 me-1"></i> 2025/2026 Academic Session</span>
                    
                    @if (SignInManager.IsSignedIn(User))
                    {
                        // Fetch the custom user from the database to get their actual names
                        var currentUser = await UserManager.GetUserAsync(User);
                        var firstName = currentUser?.FirstName ?? "Admin";
                        var lastName = currentUser?.LastName ?? "User";
                        var initials = $"{firstName.Substring(0, 1)}{lastName.Substring(0, 1)}".ToUpper();

                        <div class="d-flex align-items-center gap-3 pl-3 border-start">
                            <div class="text-end d-none d-sm-block">
                                <div class="fw-bold" style="color: var(--brand-navy); font-size: 0.95rem;">@firstName @lastName</div>
                                <div class="text-muted" style="font-size: 0.75rem;">System Access</div>
                            </div>
                            <div class="avatar-circle shadow-sm">
                                @initials
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-sm shadow-sm" style="background-color: var(--brand-navy); color: white; border-radius: 6px;">Sign In</a>
                    }
                </div>
            </header>

            <div class="content-wrapper">
                @RenderBody()
            </div>
        </main>
        
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>