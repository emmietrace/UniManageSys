@model IEnumerable<UniManageSys.Models.Programme>

<div class="d-flex justify-content-between align-items-end mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--brand-navy);">Degree Programmes</h2>
        <p class="text-muted mb-0">Manage degrees offered by the university.</p>
    </div>
    <a asp-action="Create" class="btn px-4 shadow-sm" style="background-color: var(--brand-navy); color: white; border-radius: 8px;">
        <i class="bi bi-plus-circle me-2"></i> Add Programme
    </a>
</div>
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 8px; border-left: 5px solid #10B981;">
        <i class="bi bi-shield-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 8px; border-left: 5px solid #EF4444;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm p-4" style="border-radius: 16px;">
    <table class="uni-table w-100">
        <thead>
            <tr>
                <th>Programme Name</th>
                <th>Owning Department</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold" style="color: var(--brand-navy);">@item.Name</td>
                    <td class="text-muted">@item.Department?.Name</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border shadow-sm">
                            <i class="bi bi-pencil-square text-primary"></i> Edit
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>