@model UniManageSys.Models.Programme

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold m-0" style="color: var(--brand-navy);">Add Programme</h2>
    <a asp-action="Index" class="btn btn-outline-secondary px-3">Cancel</a>
</div>

<div class="card border-0 shadow-sm p-4" style="border-radius: 16px; max-width: 600px;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="alert alert-danger shadow-sm" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Code" class="form-label text-muted fw-bold small text-uppercase">Code</label>
                <input asp-for="Code" class="form-control" placeholder="e.g. MIS" required />
            </div>

            <div class="col-md-8">
                <label asp-for="Name" class="form-label text-muted fw-bold small text-uppercase">Programme Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Management Information System" required />
            </div>
        </div>
        
        <div class="mb-4 mt-3">
            <label asp-for="DepartmentId" class="form-label text-muted fw-bold small text-uppercase">Owning Department</label>
            <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments" required>
                <option value="">-- Select Department --</option>
            </select>
        </div>

        <button type="submit" class="btn shadow-sm py-2 w-100" style="background-color: var(--brand-navy); color: white; border-radius: 8px;">
            <i class="bi bi-save me-2"></i> Save Programme
        </button>
    </form>
</div>