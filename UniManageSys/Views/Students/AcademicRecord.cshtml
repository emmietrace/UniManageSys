@model IEnumerable<UniManageSys.Models.CourseRegistration>

@{
    var student = ViewBag.Student as UniManageSys.Models.Student;
    ViewData["Title"] = "Academic Record";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 8px; border-left: 5px solid #10B981;">
        <i class="bi bi-shield-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 8px; border-left: 5px solid #EF4444;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm p-4 mt-2" style="border-radius: 16px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0" style="color: var(--brand-navy);">Academic History: @student?.User?.FirstName @student?.User?.LastName</h4>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3" style="border-radius: 6px;">
            <i class="bi bi-arrow-left me-1"></i> Back to Registry
        </a>
    </div>

    <div class="table-responsive">
        <table class="uni-table w-100 mb-0">
            <thead style="background-color: #F8FAFC;">
                <tr>
                    <th class="ps-3">Semester</th>
                    <th>Course</th>
                    <th>Units</th>
                    <th>Score</th>
                    <th>Grade</th>
                    <th class="text-end pe-3">Admin Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-5">No approved courses found for this student.</td></tr>
                }
                
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 text-muted fw-bold small align-middle">@item.Semester?.Name</td>
                        <td class="fw-bold align-middle" style="color: var(--brand-navy);">@item.Course?.Code - @item.Course?.Title</td>
                        <td class="align-middle"><span class="badge bg-light text-dark border">@item.Course?.CreditUnits CR</span></td>
                        
                        <td class="align-middle fw-bold">@(item.Result?.TotalScore.ToString() ?? "-")</td>
                        <td class="align-middle">
                            @if (item.Result?.Grade == null)
                            {
                                <span class="badge bg-secondary">N/A</span>
                            }
                            else
                            {
                                <span class="badge @(item.Result?.Grade == "F" ? "bg-danger" : "bg-success")">@item.Result?.Grade</span>
                            }
                        </td>
                        
                        <td class="text-end pe-3 align-middle">
                            <form asp-action="DropApprovedCourse" method="post" class="d-inline" onsubmit="return confirm('ADMINISTRATIVE OVERRIDE:\n\nAre you sure you want to forcibly drop @item.Course?.Code for @(student?.User?.FirstName)? This will completely remove it from their official record.');">
                                <input type="hidden" name="registrationId" value="@item.Id" />
                                <input type="hidden" name="studentId" value="@student?.Id" />
                                
                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" style="border-radius: 6px;" title="Force Drop Course">
                                    <i class="bi bi-trash3 me-1"></i> Force Drop
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>