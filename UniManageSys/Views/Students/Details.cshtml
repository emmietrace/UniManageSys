@model UniManageSys.Models.Student

<div class="card border-0 shadow-sm p-5" style="border-radius: 20px;">
    <div class="d-flex align-items-center gap-4 mb-4">
        <div class="avatar-circle shadow" style="width: 100px; height: 100px; font-size: 2.5rem;">
            @Model.User?.FirstName?[0]@Model.User?.LastName?[0]
        </div>
        <div>
            <h2 class="fw-bold m-0" style="color: var(--brand-navy);">@Model.User?.FullName</h2>
            <p class="text-muted fs-5">@Model.MatriculationNumber | @Model.CurrentLevel Level</p>
        </div>
    </div>
    <hr>
    <div class="row mt-4">
        <div class="col-md-6">
            <label class="text-muted small text-uppercase fw-bold">Programme</label>
            <p class="fs-5">@Model.Programme?.Name</p>
        </div>
        <div class="col-md-6">
            <label class="text-muted small text-uppercase fw-bold">Department</label>
            <p class="fs-5">@Model.Programme?.Department?.Name</p>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary mt-4" style="width: fit-content;">Back to Registry</a>
</div>