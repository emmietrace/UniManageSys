@model UniManageSys.Models.Student

@{
    ViewData["Title"] = "Edit Student Profile";
}

<div class="d-flex justify-content-between align-items-end mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--brand-navy);">Edit Profile</h2>
        <p class="text-muted mb-0">Updating records for @Model.MatriculationNumber</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary px-3">Cancel</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4" style="border-radius: 16px;">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="MatriculationNumber" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">First Name</label>
                        <input name="FirstName" class="form-control" value="@Model.User?.FirstName" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Last Name</label>
                        <input name="LastName" class="form-control" value="@Model.User?.LastName" required />
                    </div>

                    <div class="col-md-6 mt-4">
                        <label asp-for="CurrentLevel" class="form-label text-muted small fw-bold">Academic Level</label>
                        <select asp-for="CurrentLevel" class="form-select">
                            <option value="100">100 Level</option>
                            <option value="200">200 Level</option>
                            <option value="300">300 Level</option>
                            <option value="400">400 Level</option>
                            <option value="500">500 Level</option>
                        </select>
                    </div>

                    <div class="col-md-6 mt-4">
                        <label asp-for="ProgrammeId" class="form-label text-muted small fw-bold">Degree Programme</label>
                        <select asp-for="ProgrammeId" class="form-select" asp-items="ViewBag.Programmes"></select>
                    </div>

                    <div class="col-12 mt-5">
                        <button type="submit" class="btn px-5 shadow-sm" style="background-color: var(--brand-navy); color: white; border-radius: 8px;">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>