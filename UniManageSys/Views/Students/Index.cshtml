@model IEnumerable<UniManageSys.Models.Student>

@{
    ViewData["Title"] = "Student Registry";
}

<div class="d-flex justify-content-between align-items-end mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--brand-navy);">Student Registry</h2>
        <p class="text-muted mb-0" style="font-size: 0.95rem;">Manage all enrolled students across the university.</p>
    </div>
    <a asp-action="Enroll" class="btn px-4 shadow-sm" style="background-color: var(--brand-navy); color: white; border-radius: 8px; font-weight: 500;">
        <i class="bi bi-person-plus-fill me-2"></i> Admit Student
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 8px; border-left: 5px solid #10B981;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm p-4" style="border-radius: 16px; background-color: var(--card-bg);">
    <div class="table-responsive">
        <table class="uni-table w-100" id="registryTable">
            <thead>
                <tr>
                    <th>Matric No.</th>
                    <th>Full Name</th>
                    <th>Programme</th>
                    <th>Level</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var student in Model)
                    {
                        <tr>
                            <td class="fw-bold" style="color: var(--brand-navy);">
                                @(student.MatriculationNumber ?? "Pending...")
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-circle shadow-sm" style="width: 32px; height: 32px; font-size: 0.75rem;">
                                        @(student.User?.FirstName?.Substring(0, 1))@(student.User?.LastName?.Substring(0, 1))
                                    </div>
                                    <div>
                                        <div class="fw-semibold" style="color: var(--text-main);">@student.User?.FullName</div>
                                        <div class="text-muted" style="font-size: 0.8rem;">@student.User?.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted" style="font-size: 0.9rem;">
                                @student.Programme?.Code
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@student.CurrentLevel Lvl</span>
                            </td>
                            <td>
                                @if (student.Status == UniManageSys.Enums.StudentStatus.Active)
                                {
                                    <span class="status-badge badge-active">Active</span>
                                }
                                else if (student.Status == UniManageSys.Enums.StudentStatus.Admitted)
                                {
                                    <span class="status-badge" style="background-color: #DBEAFE; color: #1E40AF;">Admitted</span>
                                }
                                else
                                {
                                    <span class="status-badge badge-probation">@student.Status</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="Details" asp-route-id="@student.Id" class="btn btn-sm btn-light border shadow-sm" title="View Profile">
                                        <i class="bi bi-eye text-muted"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm btn-light border shadow-sm" title="Edit Student">
                                        <i class="bi bi-file-earmark-text" style="color: var(--brand-navy);"></i>
                                    </a>
                                </div>
                                <a asp-action="AcademicRecord" asp-route-id="@student.Id" class="btn btn-sm btn-light border shadow-sm ms-1" title="Academic Record">
                                    <i class="bi bi-mortarboard" style="color: var(--brand-navy);"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            No students found or data could not be loaded.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        $(document).ready(function () {
        $('#registryTable').DataTable({
        "pageLength": 10,
        "language": {
        "search": "",
        "searchPlaceholder": "Search matric or name..."
        },
        "order": [[0, "desc"]], // Sort by newest matric number first
        "dom": '<"d-flex justify-content-between align-items-center mb-3"f l>rt<"d-flex justify-content-between align-items-center mt-3"i p>'
        });
            
        // Fix standard datatables search input styling to match our enterprise UI
        $('.dataTables_filter input').addClass('form-control').css({'border-radius': '8px', 'border': '1px solid #E2E8F0'});
        });
    </script>
}