@model IEnumerable<UniManageSys.Models.Course>

@{
    ViewData["Title"] = "Course Management";
}

<div class="d-flex justify-content-between align-items-end mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--brand-navy);">Curriculum Management</h2>
        <p class="text-muted mb-0">Manage all approved university courses.</p>
    </div>
    <a asp-action="Create" class="btn px-4 shadow-sm" style="background-color: var(--brand-navy); color: white; border-radius: 8px;">
        <i class="bi bi-plus-circle me-2"></i> Add New Course
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 8px; border-left: 5px solid #10B981;">
        <i class="bi bi-shield-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 8px; border-left: 5px solid #EF4444;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm p-4" style="border-radius: 16px;">
    <table class="uni-table w-100">
        <thead>
            <tr>
                <th>Code</th>
                <th>Course Title</th>
                <th>Level</th>
                <th>Units</th>
                <th>Department</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold" style="color: var(--brand-navy);">@item.Code</td>
                    <td>@item.Title</td>
                    <td><span class="badge bg-light text-dark border">@item.Level Level</span></td>
                    <td>@item.CreditUnits Units</td>
                    <td class="text-muted">@item.Department?.Name</td>
                    <td class="text-end pe-4 align-middle">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary shadow-sm me-2" style="border-radius: 6px;">
                            <i class="bi bi-pencil-square me-1"></i> Edit
                        </a>
    
                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Registrar"))
                        {
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('DANGER:\n\nAre you sure you want to permanently delete @item.Code? This action cannot be undone.');">
                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" style="border-radius: 6px;" title="Delete Course">
                                    <i class="bi bi-trash3 me-1"></i> Delete
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>