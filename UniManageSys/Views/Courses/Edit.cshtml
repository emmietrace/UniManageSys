@model UniManageSys.Models.Course

@{
    ViewData["Title"] = "Edit Course";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold m-0" style="color: var(--brand-navy);">Edit Course</h2>
    <a asp-action="Index" class="btn btn-outline-secondary px-3">Cancel</a>
</div>

<div class="card border-0 shadow-sm p-4" style="border-radius: 16px; max-width: 800px;">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="All" class="alert alert-danger shadow-sm" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>
        
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">
            <div class="col-md-4">
                <label asp-for="Code" class="form-label text-muted fw-bold small text-uppercase">Course Code</label>
                <input asp-for="Code" class="form-control" required />
            </div>
            
            <div class="col-md-8">
                <label asp-for="Title" class="form-label text-muted fw-bold small text-uppercase">Course Title</label>
                <input asp-for="Title" class="form-control" required />
            </div>

            <div class="col-md-4">
                <label asp-for="CreditUnits" class="form-label text-muted fw-bold small text-uppercase">Credit Units</label>
                <input asp-for="CreditUnits" type="number" min="1" max="6" class="form-control" required />
            </div>

            <div class="col-md-4">
                <label asp-for="Level" class="form-label text-muted fw-bold small text-uppercase">Academic Level</label>
                <select asp-for="Level" class="form-select" required>
                    <option value="100">100 Level</option>
                    <option value="200">200 Level</option>
                    <option value="300">300 Level</option>
                    <option value="400">400 Level</option>
                    <option value="500">500 Level</option>
                </select>
            </div>

            <div class="col-md-4">
                <label asp-for="DepartmentId" class="form-label text-muted fw-bold small text-uppercase">Owning Department</label>
                <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments" required>
                    <option value="">-- Select --</option>
                </select>
            </div>

            <div class="col-12 mt-4">
                <button type="submit" class="btn px-5 shadow-sm py-2" style="background-color: var(--brand-navy); color: white; border-radius: 8px;">
                    <i class="bi bi-arrow-clockwise me-2"></i> Update Course
                </button>
            </div>
        </div>
    </form>
</div>