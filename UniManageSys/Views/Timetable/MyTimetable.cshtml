@model UniManageSys.ViewModels.PersonalTimetableViewModel

@{
    ViewData["Title"] = "My Timetable";
    // Define the school week order
    var schoolDays = new[] { DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday };
}

<div class="d-flex justify-content-between align-items-end mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--brand-navy);">Personal Timetable</h2>
        <p class="text-muted mb-0">@Model.ActiveSemester.AcademicYear?.Name - @Model.ActiveSemester.Name</p>
    </div>
    <button class="btn btn-outline-secondary px-3 shadow-sm" onclick="window.print()">
        <i class="bi bi-printer me-2"></i> Print Schedule
    </button>
</div>

@if (!Model.WeeklySchedule.Any())
{
    <div class="text-center p-5 rounded card border-0 shadow-sm" style="background-color: var(--card-bg);">
        <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
        <h4 class="mt-3 fw-bold" style="color: var(--brand-navy);">No Classes Found</h4>
        <p class="text-muted">You do not have any scheduled classes for your approved courses yet.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var day in schoolDays)
        {
            <div class="col-lg-2 col-md-4 col-sm-6 flex-grow-1">
                <div class="card border-0 shadow-sm h-100" style="background-color: #F8FAFC; border-radius: 12px;">
                    <div class="card-header border-0 py-3 text-center" style="background-color: var(--brand-navy); color: white; border-radius: 12px 12px 0 0;">
                        <h6 class="fw-bold m-0 text-uppercase tracking-wider">@day.ToString()</h6>
                    </div>
                    <div class="card-body p-2 p-md-3">
                        @if (Model.WeeklySchedule.ContainsKey(day))
                        {
                            foreach (var cls in Model.WeeklySchedule[day])
                            {
                                <div class="card border border-light shadow-sm mb-3" style="border-radius: 8px;">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <span class="badge bg-light text-dark border">@cls.Course?.Code</span>
                                            <span class="fw-bold text-success" style="font-size: 0.8rem;">
                                                @cls.StartTime.ToString(@"hh\:mm") - @cls.EndTime.ToString(@"hh\:mm")
                                            </span>
                                        </div>
                                        <h6 class="fw-bold mb-1" style="color: var(--brand-navy); font-size: 0.9rem;">@cls.Course?.Title</h6>
                                        <div class="text-muted mt-2" style="font-size: 0.8rem;">
                                            <div><i class="bi bi-geo-alt-fill me-1 text-danger"></i> @cls.Venue?.Name</div>
                                            <div class="mt-1"><i class="bi bi-person-video3 me-1 text-primary"></i> @cls.Lecturer?.User?.LastName</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted p-3 small">
                                <em>Free Day</em>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    /* Hide the sidebar and top header when the student prints their schedule */
    @@media print {
        .sidebar, .top-header, .btn-outline-secondary { display: none !important; }
        .main-content { margin-left: 0 !important; width: 100% !important; padding: 0 !important; }
        .card { box-shadow: none !important; border: 1px solid #ddd !important; break-inside: avoid; }
    }
</style>