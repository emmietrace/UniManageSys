@model UniManageSys.ViewModels.ProfileSettingsViewModel

@{
    ViewData["Title"] = "Account Settings";
}

<div class="d-flex justify-content-between align-items-end mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--brand-navy);">Account Settings</h2>
        <p class="text-muted mb-0">Manage your personal information and security preferences.</p>
    </div>
    <div class="text-end">
        <span class="badge bg-primary px-3 py-2 shadow-sm">Role: @Model.Role</span>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4 mb-5">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
            <h5 class="fw-bold mb-4" style="color: var(--brand-navy); border-bottom: 2px solid #F8FAFC; padding-bottom: 10px;">
                <i class="bi bi-person-lines-fill me-2 text-primary"></i> Personal Information
            </h5>
            
            <form asp-action="UpdateProfile" method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label text-muted small fw-bold text-uppercase">First Name</label>
                        <input asp-for="FirstName" class="form-control" style="border-radius: 8px;" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label text-muted small fw-bold text-uppercase">Last Name</label>
                        <input asp-for="LastName" class="form-control" style="border-radius: 8px;" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold text-uppercase">University Email (Read-Only)</label>
                        <input asp-for="Email" class="form-control bg-light text-muted" style="border-radius: 8px;" readonly />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label text-muted small fw-bold text-uppercase">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+123..." style="border-radius: 8px;" />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.MatricNumber))
                    {
                        <div class="col-12 mt-3">
                            <div class="p-3 bg-light rounded" style="border: 1px dashed #cbd5e1;">
                                <span class="text-muted small fw-bold text-uppercase">Official Matriculation Number:</span>
                                <span class="fw-bold ms-2" style="color: var(--brand-navy);">@Model.MatricNumber</span>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.DepartmentCode))
                    {
                        <div class="col-12 mt-3">
                            <div class="p-3 bg-light rounded" style="border: 1px dashed #cbd5e1;">
                                <span class="text-muted small fw-bold text-uppercase">Assigned Department:</span>
                                <span class="fw-bold ms-2" style="color: var(--brand-navy);">@Model.DepartmentCode</span>
                            </div>
                        </div>
                    }

                    <div class="col-12 mt-4 text-end">
                        <button type="submit" class="btn px-4 py-2 shadow-sm" style="background-color: var(--brand-navy); color: white; border-radius: 8px;">
                            Save Changes
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
            <h5 class="fw-bold mb-4" style="color: #EF4444; border-bottom: 2px solid #F8FAFC; padding-bottom: 10px;">
                <i class="bi bi-shield-lock-fill me-2"></i> Security
            </h5>
            
            <form asp-action="ChangePassword" method="post">
                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label text-muted small fw-bold text-uppercase">Current Password</label>
                    <input asp-for="CurrentPassword" type="password" class="form-control" style="border-radius: 8px;" required />
                </div>
                
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label text-muted small fw-bold text-uppercase">New Password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" style="border-radius: 8px;" required />
                    <div class="form-text small">Must be at least 6 characters with a symbol and number.</div>
                </div>
                
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label text-muted small fw-bold text-uppercase">Confirm New Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" style="border-radius: 8px;" required />
                </div>

                <div class="d-grid mt-auto">
                    <button type="submit" class="btn btn-danger py-2 shadow-sm" style="border-radius: 8px;">
                        Update Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}