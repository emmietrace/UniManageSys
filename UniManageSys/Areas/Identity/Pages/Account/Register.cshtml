@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 p-5 shadow-lg" style="border-radius: 16px; background-color: var(--card-bg);">
            
            <div class="text-center mb-4">
                <h3 style="color: var(--brand-navy); font-weight: 700; margin-bottom: 0;">Portal Registration</h3>
                <p class="text-muted mt-2" style="font-size: 0.95rem;">Authorized personnel and students only.</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.FirstName" class="form-control" aria-required="true" placeholder="First Name" style="border-radius: 8px; border: 1px solid #E2E8F0;" />
                            <label asp-for="Input.FirstName" class="text-muted">First Name</label>
                            <span asp-validation-for="Input.FirstName" class="text-danger" style="font-size: 0.85rem;"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.LastName" class="form-control" aria-required="true" placeholder="Last Name" style="border-radius: 8px; border: 1px solid #E2E8F0;" />
                            <label asp-for="Input.LastName" class="text-muted">Last Name</label>
                            <span asp-validation-for="Input.LastName" class="text-danger" style="font-size: 0.85rem;"></span>
                        </div>
                    </div>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" style="border-radius: 8px; border: 1px solid #E2E8F0;" />
                    <label asp-for="Input.Email" class="text-muted">University Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" style="border-radius: 8px; border: 1px solid #E2E8F0;" />
                    <label asp-for="Input.Password" class="text-muted">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" style="border-radius: 8px; border: 1px solid #E2E8F0;" />
                    <label asp-for="Input.ConfirmPassword" class="text-muted">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn w-100 py-2 mb-3 shadow-sm" style="background-color: var(--brand-navy); color: white; border-radius: 8px; font-weight: 600; letter-spacing: 0.02em;">Create Account</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}